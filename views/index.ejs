<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Charizard Card Prices</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

    <!-- Floating header -->
    <header class="header">
        <h1><span>Charizard</span> Price Tracker</h1>
        <% if (lastUpdated) { %>
        <div class="last-updated">Updated <%= new Date(lastUpdated).toLocaleString() %></div>
        <% } %>
    </header>

    <!-- Detail panel — clip wrapper prevents backdrop-filter bleed into header -->
    <div class="detail-wrapper">
    <div class="detail-panel" id="detail-panel">
        <div class="detail-header">
            <div class="detail-title" id="detail-title"></div>
            <div class="detail-meta">
                <div class="detail-legend">
                    <div class="legend-item"><div class="legend-dot g9"></div>PSA 9</div>
                    <div class="legend-item"><div class="legend-dot g95"></div>PSA 9.5</div>
                    <div class="legend-item"><div class="legend-dot g10"></div>PSA 10</div>
                </div>
                <div class="range-btns">
                    <button class="range-btn<%= range === '1w' ? ' active' : '' %>" onclick="changeRange('1w')">1W</button>
                    <button class="range-btn<%= range === '1m' ? ' active' : '' %>" onclick="changeRange('1m')">1M</button>
                    <button class="range-btn<%= range === '3m' ? ' active' : '' %>" onclick="changeRange('3m')">3M</button>
                    <button class="range-btn<%= range === '6m' ? ' active' : '' %>" onclick="changeRange('6m')">6M</button>
                    <button class="range-btn<%= range === '1y' ? ' active' : '' %>" onclick="changeRange('1y')">1Y</button>
                    <button class="range-btn<%= range === 'max' ? ' active' : '' %>" onclick="changeRange('max')">MAX</button>
                </div>
            </div>
        </div>
        <div class="detail-chart">
            <canvas id="detail-chart"></canvas>
        </div>
    </div>
    </div><!-- end detail-wrapper -->

    <!-- Bottom dock -->
    <div class="dock">
        <% cards.forEach(function(card, idx) { %>
        <div class="dock-card" data-idx="<%= idx %>" onclick="selectCard(<%= idx %>)">
            <img src="<%= card.image %>" alt="<%= card.name %>">
            <div class="dock-card-info">
                <div class="dock-card-name"><%= shortName(card.name) %></div>
                <div class="dock-prices">
                    <div class="dock-price-row g9">
                        <span class="grade">PSA 9</span>
                        <span class="price"><%= card.prices.grade_9 %></span>
                        <span class="delta" data-idx="<%= idx %>" data-grade="9"></span>
                    </div>
                    <div class="dock-price-row g95">
                        <span class="grade">PSA 9.5</span>
                        <span class="price"><%= card.prices.grade_9_5 %></span>
                        <span class="delta" data-idx="<%= idx %>" data-grade="95"></span>
                    </div>
                    <div class="dock-price-row g10">
                        <span class="grade">PSA 10</span>
                        <span class="price"><%= card.prices.grade_10 %></span>
                        <span class="delta" data-idx="<%= idx %>" data-grade="10"></span>
                    </div>
                </div>
            </div>
            <div class="dock-sparkline">
                <canvas id="spark-<%= idx %>"></canvas>
            </div>
        </div>
        <% }); %>
    </div>

    <script>
    var allCardData = [];
    <% cards.forEach(function(card, idx) { %>
    allCardData.push({
      name: '<%= shortName(card.name) %>',
      h9:  <%- JSON.stringify(card.history9  || []) %>,
      h95: <%- JSON.stringify(card.history95 || []) %>,
      h10: <%- JSON.stringify(card.history10 || []) %>
    });
    <% }); %>

    var selectedCard = -1;
    var detailChart = null;

    var COLORS = {
      g9:  { border: '#f59e0b', bg: 'rgba(245,158,11,0.12)' },
      g95: { border: '#ef4444', bg: 'rgba(239,68,68,0.12)' },
      g10: { border: '#ff6b35', bg: 'rgba(255,107,53,0.12)' }
    };

    function buildChartData(card) {
      var allTs = {};
      card.h9.forEach(function(h)  { allTs[h.timestamp] = true; });
      card.h95.forEach(function(h) { allTs[h.timestamp] = true; });
      card.h10.forEach(function(h) { allTs[h.timestamp] = true; });
      var timestamps = Object.keys(allTs).sort();
      function lookup(hist) {
        var map = {};
        hist.forEach(function(h) { map[h.timestamp] = h.price; });
        return timestamps.map(function(ts) { return map[ts] || null; });
      }
      return { labels: timestamps, d9: lookup(card.h9), d95: lookup(card.h95), d10: lookup(card.h10) };
    }

    // % change badges — first vs last point of the visible range, per grade
    function pctChange(hist) {
      if (!hist || hist.length < 2) return null;
      var first = hist[0].price, last = hist[hist.length - 1].price;
      if (!first) return null;
      return ((last - first) / first) * 100;
    }
    allCardData.forEach(function(card, idx) {
      [['9', card.h9], ['95', card.h95], ['10', card.h10]].forEach(function(pair) {
        var pct = pctChange(pair[1]);
        var el = document.querySelector('.delta[data-idx="' + idx + '"][data-grade="' + pair[0] + '"]');
        if (!el) return;
        if (pct === null) { el.textContent = ''; return; }
        var sign = pct > 0 ? '+' : '';
        el.textContent = sign + pct.toFixed(1) + '%';
        el.classList.add(pct >= 0 ? 'up' : 'down');
      });
    });

    // Sparklines — color tinted by PSA 10 trend over the visible range
    allCardData.forEach(function(card, idx) {
      var data = buildChartData(card);
      var canvas = document.getElementById('spark-' + idx);
      if (!canvas) return;
      var pct = pctChange(card.h10);
      var trend = pct === null ? 'flat' : (pct >= 0 ? 'up' : 'down');
      var stroke = trend === 'up' ? '#4ade80' : trend === 'down' ? '#f87171' : COLORS.g10.border;
      var fill   = trend === 'up' ? 'rgba(74,222,128,0.12)' : trend === 'down' ? 'rgba(248,113,113,0.12)' : COLORS.g10.bg;
      new Chart(canvas.getContext('2d'), {
        type: 'line',
        data: {
          labels: data.labels,
          datasets: [{ data: data.d10, borderColor: stroke, backgroundColor: fill, fill: true, tension: 0.4, pointRadius: 0, borderWidth: 1.5 }]
        },
        options: {
          responsive: false,
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: { x: { display: false }, y: { display: false } },
          animation: { duration: 0 }
        }
      });
    });

    function selectCard(idx) {
      // Toggle off if same card clicked again
      if (selectedCard === idx) {
        selectedCard = -1;
        document.querySelectorAll('.dock-card').forEach(function(el) { el.classList.remove('active'); });
        document.getElementById('detail-panel').classList.remove('visible');
        return;
      }

      selectedCard = idx;
      document.querySelectorAll('.dock-card').forEach(function(el, i) {
        el.classList.toggle('active', i === idx);
      });

      var card = allCardData[idx];
      document.getElementById('detail-title').textContent = card.name;
      document.getElementById('detail-panel').classList.add('visible');

      renderDetailChart(card);
    }

    function renderDetailChart(card) {
      var data = buildChartData(card);
      var canvas = document.getElementById('detail-chart');
      if (detailChart) { detailChart.destroy(); }

      // All-time high across PSA 10 in the visible range
      var ath = null;
      card.h10.forEach(function(h) { if (ath === null || h.price > ath) ath = h.price; });
      var athPlugin = {
        id: 'athLine',
        afterDatasetsDraw: function(chart) {
          if (ath === null) return;
          var ctx = chart.ctx;
          var yScale = chart.scales.y;
          var y = yScale.getPixelForValue(ath);
          if (!isFinite(y) || y < chart.chartArea.top || y > chart.chartArea.bottom) return;
          ctx.save();
          ctx.strokeStyle = 'rgba(255,255,255,0.25)';
          ctx.setLineDash([4, 4]);
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(chart.chartArea.left, y);
          ctx.lineTo(chart.chartArea.right, y);
          ctx.stroke();
          ctx.setLineDash([]);
          ctx.fillStyle = 'rgba(255,255,255,0.55)';
          ctx.font = '10px Inter, sans-serif';
          ctx.textAlign = 'left';
          ctx.fillText('ATH  $' + ath.toLocaleString(), chart.chartArea.left + 6, y - 4);
          ctx.restore();
        }
      };

      detailChart = new Chart(canvas.getContext('2d'), {
        plugins: [athPlugin],
        type: 'line',
        data: {
          labels: data.labels,
          datasets: [
            { label: 'PSA 9',   data: data.d9,  borderColor: COLORS.g9.border,  backgroundColor: COLORS.g9.bg,  fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, borderWidth: 2, spanGaps: true },
            { label: 'PSA 9.5', data: data.d95, borderColor: COLORS.g95.border, backgroundColor: COLORS.g95.bg, fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, borderWidth: 2, spanGaps: true },
            { label: 'PSA 10',  data: data.d10, borderColor: COLORS.g10.border, backgroundColor: COLORS.g10.bg, fill: true, tension: 0.35, pointRadius: 0, pointHoverRadius: 5, borderWidth: 2, spanGaps: true }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: 'rgba(5,5,15,0.92)',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              titleColor: 'rgba(255,255,255,0.5)',
              bodyColor: '#fff',
              padding: 10,
              cornerRadius: 8,
              titleFont: { size: 11 },
              bodyFont: { size: 12, weight: '600' },
              callbacks: {
                title: function(ctx) { return new Date(ctx[0].label).toLocaleString(); },
                label: function(ctx) {
                  if (ctx.parsed.y === null) return null;
                  return ' ' + ctx.dataset.label + ':  $' + ctx.parsed.y.toLocaleString();
                }
              }
            }
          },
          scales: {
            x: {
              display: true,
              grid: { color: 'rgba(255,255,255,0.04)' },
              ticks: {
                color: 'rgba(255,255,255,0.25)',
                font: { size: 10 },
                maxTicksLimit: 8,
                callback: function(value) {
                  return new Date(this.getLabelForValue(value)).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                }
              }
            },
            y: {
              display: true,
              position: 'right',
              grid: { color: 'rgba(255,255,255,0.04)' },
              ticks: {
                color: 'rgba(255,255,255,0.25)',
                font: { size: 10 },
                callback: function(v) { return '$' + v.toLocaleString(); }
              }
            }
          }
        }
      });
    }

    function changeRange(range) {
      window.location.href = '/?range=' + range;
    }
    </script>
</body>
</html>

<% function shortName(name) {
  if (name === 'Charizard Pokemon Japanese Expansion Pack 1996') return 'Japanese 1996';
  if (name === 'Charizard Pokemon Base Set 2') return 'Base Set 2';
  if (name === 'Charizard Pokemon Base Set') return 'Base Set';
  if (name === 'Charizard Pokemon Shadowless') return 'Shadowless';
  if (name === 'Charizard Pokemon First Edition') return '1st Edition';
  return name;
} %>
